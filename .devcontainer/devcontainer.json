// See https://containers.dev/implementors/json_reference/ for configuration reference
{
	"name": "React Upskill - basic",
	"build": {
		"dockerfile": "Dockerfile"
	},
  "remoteUser": "node",
	"forwardPorts": [3000],
	"portsAttributes": {
		"3000": {
			"label": "Frontend",
			"onAutoForward": "notify"
		}
	},
	"runArgs": [ "--sysctl", "net.ipv6.conf.all.disable_ipv6=1"]
}
